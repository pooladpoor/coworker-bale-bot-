# --- Secrets (required) ---
BALE_TOKEN=your_bale_bot_token
COMETAPI_KEY=your_cometapi_key

# --- CometAPI ---
COMETAPI_BASE_URL=https://api.cometapi.com/v1
COMETAPI_GPT_MODEL=gpt-5.6-sol
COMETAPI_GEMINI_MODEL=gemini-3-flash
COMETAPI_CLAUDE_MODEL=claude-sonnet-4-6

# --- Concurrency / queue ---
WORKER_COUNT=8
QUEUE_MAX_SIZE=1000

# --- HTTP timeouts (seconds) ---
HTTP_TIMEOUT_TOTAL=60
HTTP_TIMEOUT_CONNECT=10
AI_REQUEST_TIMEOUT=90
MAX_RETRIES=3
RETRY_BACKOFF_BASE=1.5
CONNECTOR_LIMIT=100
CONNECTOR_LIMIT_PER_HOST=30

# --- Polling ---
POLLING_TIMEOUT=10
POLLING_ERROR_BACKOFF=3

# --- Misc ---
LOG_LEVEL=INFO
MIN_VALID_IMAGE_BYTES=1000

# --- Group behaviour ---
# When true, the bot only answers a photo posted in a group/supergroup if
# its caption @-mentions the bot (e.g. "@your_bot_username سوال رو ببین").
# Private chats always respond regardless of this setting.
GROUP_REQUIRE_MENTION=true
# Optional: set this to skip the getMe() lookup at startup (must match the
# bot's actual @username, without the @).
BOT_USERNAME=
