# --- Secrets (required) ---
BALE_TOKEN=your_bale_bot_token

# --- AI model providers ---
# Each of the three models is FULLY independent: its own platform
# (base URL), its own API key, and its own model name. Point each one at
# any OpenAI-compatible platform you like -- CometAPI, OpenRouter, a
# direct provider API, a self-hosted gateway, etc. They do not need to
# be on the same platform as each other.
#
# Expected endpoints on each base URL:
#   Gemini / Claude -> {BASE_URL}/chat/completions
#   GPT              -> {BASE_URL}/responses

GEMINI_BASE_URL=https://api.cometapi.com/v1
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash

CLAUDE_BASE_URL=https://api.cometapi.com/v1
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-6

GPT_BASE_URL=https://api.cometapi.com/v1
GPT_API_KEY=your_gpt_api_key
GPT_MODEL=gpt-5.6-sol

# --- Concurrency / queue ---
WORKER_COUNT=8
QUEUE_MAX_SIZE=1000

# --- HTTP timeouts (seconds) ---
HTTP_TIMEOUT_TOTAL=60
HTTP_TIMEOUT_CONNECT=10
AI_REQUEST_TIMEOUT=90
MAX_RETRIES=3
RETRY_BACKOFF_BASE=1.5
CONNECTOR_LIMIT=100
CONNECTOR_LIMIT_PER_HOST=30

# --- Polling ---
POLLING_TIMEOUT=10
POLLING_ERROR_BACKOFF=3

# --- Misc ---
LOG_LEVEL=INFO
MIN_VALID_IMAGE_BYTES=1000

# --- Group behaviour ---
# When true, the bot only answers a photo posted in a group/supergroup if
# its caption @-mentions the bot (e.g. "@your_bot_username سوال رو ببین").
# Private chats always respond regardless of this setting.
GROUP_REQUIRE_MENTION=true
# Optional: set this to skip the getMe() lookup at startup (must match the
# bot's actual @username, without the @).
BOT_USERNAME=

# --- Access control ---
# Comma-separated list of numeric Bale user IDs allowed to use the bot
# (checked against the sender's own id, works in both private chats and
# groups). Leave empty to allow everyone (default). Anyone not on this
# list gets a polite rejection message instead of an answer.
# Example: ALLOWED_USER_IDS=1467878993,987654321
ALLOWED_USER_IDS=
